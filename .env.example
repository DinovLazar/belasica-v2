# Formspree endpoint for the /kontakt form. Public form action (not a secret) — wired in Phase 3.03. Leave empty here; while unset the form renders visibly disabled.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Sanity write token — SECRET, LOCAL ONLY. Used exclusively by the Phase 2.09 ingestion
# script (scripts/ingest/) to create season + photo documents. Editor permission on the
# `production` dataset. Never NEXT_PUBLIC, never committed, never added to Vercel — the site
# itself stays token-free (D-1.04-2). Put the real value in .env.local (git-ignored); leave
# this template empty. The script exits with an error if it is unset when run with --commit.
SANITY_API_WRITE_TOKEN=
